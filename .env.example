QOBRIX_API_URL=https://yourcrm.qobrix.com
QOBRIX_API_USER=your-api-user-uuid
QOBRIX_API_KEY=your-api-key
QOBRIX_LOCALE=en-US

# ---------------------------------------------------------------------------
# Response cache (optional, on by default)
# ---------------------------------------------------------------------------
# Tier 1 is an in-process LRU; Tier 2 is Redis (only used when QOBRIX_REDIS_URL is set).
# Single-flight coalescing prevents stampede when parallel tool calls hit the same key.
# See README.md "Caching" for design notes and recommended Redis server config.

# Set to "false" to disable the cache entirely.
QOBRIX_CACHE_ENABLED=true

# TTL in seconds. CRM users will see new records / edits at most this many seconds late.
# Use qobrix_cache_clear for an instant refresh.
QOBRIX_CACHE_TTL=300

# Max entries in the in-memory LRU tier.
QOBRIX_CACHE_MAX_ENTRIES=5000

# Optional Redis tier. Leave empty for memory-only.
# Supports redis:// and rediss://. Requires `npm install redis` (already in optionalDependencies).
QOBRIX_REDIS_URL=

# Namespace for keys when sharing a Redis instance across apps.
QOBRIX_REDIS_KEY_PREFIX=qobrix:
